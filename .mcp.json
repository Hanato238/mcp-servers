{
  "mcpServers": {
    "brightdata": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@brightdata/mcp-server"],
      "env": { "BRIGHTDATA_API_KEY": "${BRIGHTDATA_API_KEY}" }
    },
    "drawio": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@jgraph/drawio-mcp"],
      "env": {}
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp"],
      "env": {}
    },
    "browser": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-browser-tools"],
      "env": {}
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": { "GITHUB_MCP_PAT": "${GITHUB_MCP_PAT}" }
    },
    "google-workspace": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@googleworkspace/mcp-server"],
      "env": {}
    },
    "todoist": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@doist/mcp-server-todoist"],
      "env": { "TODOIST_API_KEY": "${TODOIST_API_KEY}" }
    },
    "figma": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@figma/mcp-server"],
      "env": { "FIGMA_API_KEY": "${FIGMA_API_KEY}" }
    },
    "huggingface": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@huggingface/mcp-server"],
      "env": { "HF_TOKEN": "${HF_TOKEN}" }
    },
    "perplexity": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@perplexity-ai/mcp-server"],
      "env": { "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}" }
    },
    "amazon-seller": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "amazon-sp-api-mcp-server"],
      "env": {}
    },
    "keepa": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "keepa-mcp-server"],
      "env": { "KEEPA_API_KEY": "${KEEPA_API_KEY}" }
    },
    "aws-iam": {
      "type": "stdio",
      "command": "uvx",
      "args": ["awslabs.iam-mcp-server@latest"],
      "env": {}
    },
    "google-maps": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@googlemaps/code-assist-mcp@latest"],
      "env": {}
    },
    "observability": {
      "type": "stdio",
      "command": "uvx",
      "args": ["observability-mcp"],
      "env": {}
    },
    "markitdown": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@microsoft/markitdown-mcp"],
      "env": {}
    },
    "notebooklm": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "notebooklm-mcp@latest"],
      "env": {}
    },
    "youtube": {
      "type": "stdio",
      "command": "uvx",
      "args": ["youtube-mcp-server"],
      "env": {}
    },
    "serena": {
      "type": "stdio",
      "command": "uvx",
      "args": ["serena-mcp"],
      "env": {}
    },
    "openevidence": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "openevidence-mcp"],
      "env": {}
    },
    "desktop-commander": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@wonderwhy-er/desktop-commander"],
      "env": {}
    }
  }
}
